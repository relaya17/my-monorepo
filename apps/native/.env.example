# Expo environment variables — copy to .env and fill in your values.
# All EXPO_PUBLIC_ vars are bundled into the client (never put secrets here).

# API base URL (no trailing slash)
EXPO_PUBLIC_API_URL=https://my-monorepo-1.onrender.com/api

# WebSocket URL for real-time events
EXPO_PUBLIC_SOCKET_URL=wss://my-monorepo-1.onrender.com

# Environment name
EXPO_PUBLIC_APP_ENV=development

# Optional: Sentry DSN for error tracking
# EXPO_PUBLIC_SENTRY_DSN=https://xxxxx@sentry.io/yyyyy
